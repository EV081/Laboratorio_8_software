[run]
relative_files = True
omit =
    */__init__.py
    */main.py
    */config.py
    tests/*
    tests/**/*
    consumer-rabbit.py
    producer-rabbit.py
    consumer-kafka.py
    producer-kafka.py

[report]
exclude_lines =
    pragma: no cover
    raise NotImplementedError
    if __name__ == .__main__.:
